# =================================================================
# iCARE++ mobile environment variables
# Copy this file to `.env` and fill in real values.
# Only EXPO_PUBLIC_* variables are exposed to the app bundle.
# =================================================================

# --- Backend API ---------------------------------------------------------
# Base URL of the icare web app (its Next.js API routes serve mobile too).
# Use your machine's LAN IP when testing on a physical device, e.g.
# http://192.168.1.10:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
