# =================================================================
# iCARE++ mobile environment variables
# Copy this file to `.env` and fill in real values.
# Only EXPO_PUBLIC_* variables are exposed to the app bundle.
# =================================================================

# --- Backend API ---------------------------------------------------------
# Base URL of the icare web app (its Next.js API routes serve mobile too).
# Use your machine's LAN IP when testing on a physical device, e.g.
# http://192.168.1.10:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Google Sign-In -------------------------------------------------------
# https://console.cloud.google.com/apis/credentials
# The web client ID is enough to test the implicit id_token flow in Expo Go;
# add its redirect URI (shown by the app / expo-auth-session at runtime) to
# that OAuth client's "Authorized redirect URIs" in Google Cloud Console.
# iOS/Android client IDs are only needed for a standalone or dev-client build
# and must be the corresponding "iOS"/"Android" client type (not "Web"), so
# they must also be added on the server as GOOGLE_IOS_CLIENT_ID /
# GOOGLE_ANDROID_CLIENT_ID (see web/.env.example) or the ID token won't verify.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
