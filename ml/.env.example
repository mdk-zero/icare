# Supabase project (same values the web app uses)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Shared secret the Next.js server sends in the X-ICARE-ML-KEY header.
# Must match ML_SERVICE_SECRET in web/.env.local.
ML_SERVICE_SECRET=change-me

# at_risk when P(at_risk) >= threshold
ML_RISK_THRESHOLD=0.5

# Which active model writes performance_predictions: random_forest | logistic_regression
ML_PRIMARY_MODEL_KIND=random_forest

# Nightly batch predictions + recommendation refresh (24h local time)
ML_SCHEDULE_ENABLED=true
ML_SCHEDULE_TIME=03:00

# Default number of quiz recommendations per student
ML_RECOMMEND_K=5
